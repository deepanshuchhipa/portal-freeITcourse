<%@ Page 
    Title="Career-Focused Tech Education Platform | FreeITLearning.com" 
    Language="C#" 
    MasterPageFile="~/MasterPage.master" 
    AutoEventWireup="true" 
    CodeFile="about.aspx.cs" 
    Inherits="_about" %>
<asp:Content ID="Content1" ContentPlaceHolderID="head" Runat="Server">
</asp:Content>
<asp:Content ID="Content2" ContentPlaceHolderID="ContentPlaceHolder1" Runat="Server">
        <section class="ixl-breadcrumb-one" style="background: url(assets/images/breadcrumb.png);">
                    <div class="container">
                        <div class="ixl-breadcrumb-wrapper">
                            <div class="row">
                                <div class="col-12">
                                    <div class="ixl-breadcrumb">
                                        <h1 class="ixl-heading-xl text-anime-style-2" data-aos="fade-up"
                                            data-aos-delay="400" data-aos-duration="1500">About us</h1>
                                        <ul data-aos="fade-up" data-aos-delay="600" data-aos-duration="1500">
                                            <li class="ixl-heading-sm"><a href="index.aspx">Home</a> <i
                                                    class="fa-solid fa-angle-right"></i> </li>
                                            <li class="ixl-heading-sm">About</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!--about section start-->
                <section class="ixl-about-one pt-120 about-page-about-one">

    <div class="container">

        <div class="ixl-about-one-wrapper">

            <div class="row">

                <!-- LEFT IMAGES -->
                <div class="col-lg-6">

                    <div class="ixl-about-one-images">

                        <img src="assets/images/home-v1/about/about-line.png"
                            class="image-01"
                            alt="about-line">

                        <img src="assets/images/home-v1/about/about-01.png"
                            class="image-02 parallax-img-down"
                            alt="about-image">

                        <img src="assets/images/home-v1/about/about-02.png"
                            class="image-03"
                            alt="about-image">

                        <!-- SMALL BOX -->
                        <div class="img-box parallax-move-left">

                            <div class="icon">

                                <img src="assets/images/home-v1/about/about-icon-03.svg"
                                    alt="about-icon">

                            </div>

                            <div class="img-box-content">

                                <p class="ixl-heading-sm mb-2">
                                    Daily Learning
                                </p>

                                <span>
                                    Free IT Training Platform
                                </span>

                            </div>

                        </div>

                    </div>

                </div>

                <div class="col-lg-1"></div>

                <!-- RIGHT CONTENT -->
                <div class="col-lg-5">

                    <div class="ixl-about-one-right">

                        <h1 class="ixl-heading-xl text-anime-style-2">
                            Build Your Future With Free IT Courses
                        </h1>

                        <p>
                            Learn modern technology skills with free professional IT courses.
                            Start your journey in web development programming cyber security
                            and software development with practical training and real projects.
                        </p>

                        <div class="ixl-about-info-wrapper">

                            <!-- BOX 1 -->
                            <div class="ixl-about-info"
                                data-aos="fade-up"
                                data-aos-duration="1200">

                                <img src="assets/images/home-v1/about/about-icon-01.svg"
                                    alt="about-icon">

                                <h2 class="ixl-heading-sm">
                                    Learn Web Development & Programming
                                </h2>

                            </div>

                            <!-- BOX 2 -->
                            <div class="ixl-about-info"
                                data-aos="fade-up"
                                data-aos-duration="1500">

                                <img src="assets/images/home-v1/about/about-icon-02.svg"
                                    alt="about-icon">

                                <h2 class="ixl-heading-sm">
                                    Improve Skills With Practical Projects
                                </h2>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>



                <!-- service section start -->
                <section class="ixl-service-two ptb-120">
    <div class="container">

        <div class="ixl-service-two-wrapper">

            <div class="row align-items-center justify-content-center">
                <div class="col-lg-5">

                    <h1 class="ixl-heading-xl service-two-heading" data-aos="fade-up">
                        Free IT Courses
                        <img src="assets/images/home-v2/service/heading.svg" alt="">
                    </h1>

                </div>
            </div>

            <div class="row gy-4">

                <!-- CARD 1 -->
                <div class="col-md-6">

                    <div class="ixl-service-two-item"
                        data-aos="fade-up"
                        data-aos-delay="300"
                        data-aos-duration="800">

                        <div class="img">
                            <img src="assets/images/home-v2/service/service-01.svg"
                                alt="service-img"
                                class="img-fluid">
                        </div>

                        <div class="content">

                            <a href="#">
                                <h2 class="ixl-heading-md bg-line-underline">
                                    Web Development
                                </h2>
                            </a>

                            <p>
                                Learn HTML CSS JavaScript Bootstrap and responsive website design from scratch.
                            </p>

                        </div>

                    </div>

                </div>

                <!-- CARD 2 -->
                <div class="col-md-6">

                    <div class="ixl-service-two-item two"
                        data-aos="fade-up"
                        data-aos-delay="400"
                        data-aos-duration="1000">

                        <div class="img">
                            <img src="assets/images/home-v2/service/service-02.svg"
                                alt="service-img"
                                class="img-fluid">
                        </div>

                        <div class="content">

                            <a href="#">
                                <h2 class="ixl-heading-md bg-line-underline">
                                    ASP.NET Development
                                </h2>
                            </a>

                            <p>
                                Build dynamic web applications using ASP.NET Web Forms and SQL Server database.
                            </p>

                        </div>

                    </div>

                </div>

                <!-- CARD 3 -->
                <div class="col-md-6">

                    <div class="ixl-service-two-item three"
                        data-aos="fade-up"
                        data-aos-delay="500"
                        data-aos-duration="1200">

                        <div class="img">
                            <img src="assets/images/home-v2/service/service-03.svg"
                                alt="service-img"
                                class="img-fluid">
                        </div>

                        <div class="content">

                            <a href="#">
                                <h2 class="ixl-heading-md bg-line-underline">
                                    Python Programming
                                </h2>
                            </a>

                            <p>
                                Master Python basics automation logic building and real world programming concepts.
                            </p>

                        </div>

                    </div>

                </div>

                <!-- CARD 4 -->
                <div class="col-md-6">

                    <div class="ixl-service-two-item four"
                        data-aos="fade-up"
                        data-aos-delay="600"
                        data-aos-duration="1400">

                        <div class="img">
                            <img src="assets/images/home-v2/service/service-04.svg"
                                alt="service-img"
                                class="img-fluid">
                        </div>

                        <div class="content">

                            <a href="#">
                                <h2 class="ixl-heading-md bg-line-underline">
                                    Cyber Security
                                </h2>
                            </a>

                            <p>
                                Learn ethical hacking network security cyber attacks and data protection techniques.
                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>
</section>

       

                <!--testimonal slider item-->
                <section class="ixl-testimonial-one pt-120 about-page-testimonial-one">
    <div class="container">
        <div class="ixl-teatimonial-one-wrap">

            <div class="row align-items-center justify-content-between mb-4">
                <div class="col-lg-6">
                    <h2 class="ixl-heading-xl text-anime-style-2 testimonial-slider-heading">
                        Your Vision, Our Passion the Outstanding Results
                    </h2>
                </div>

                <div class="col-lg-6">
                    <div class="testimonial-one-slider-arrow-wrapper">
                        <div class="teatimonial-slider-arrows">
                            <div class="swiper-button-next">
                                <i class="fa-regular fa-arrow-right"></i>
                            </div>

                            <div class="swiper-button-prev">
                                <i class="fa-regular fa-arrow-left"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="ixl-testimonial-wrapper">
                <div class="row">

                    <div class="col-lg-5">

                        <div class="swiper testimonial-slider-one">

                            <div class="swiper-wrapper">

                                <asp:Repeater ID="rptTestimonial" runat="server">

                                    <ItemTemplate>

                                        <div class="swiper-slide">

                                            <div class="ixl-testimonial-item-one">

                                                <div class="testimonial-info">

                                                    <div class="author">

                                                     

                                                        <div class="autor-info">

                                                            <!-- STATIC RATING -->
                                                            <div class="rating">
                                                                <i class="fa-solid fa-star"></i>
                                                                <i class="fa-solid fa-star"></i>
                                                                <i class="fa-solid fa-star"></i>
                                                                <i class="fa-solid fa-star"></i>
                                                                <i class="fa-solid fa-star"></i>
                                                            </div>

                                                            <!-- DYNAMIC NAME -->
                                                            <h3 class="ixl-heading-sm bg-line-underline">
                                                                <%# Eval("student_name") %>
                                                            </h3>

                                                            <span>Student</span>

                                                        </div>
                                                    </div>

                                                    <img src="assets/images/home-v1/testimonial/quote.svg"
                                                        alt="quote">

                                                </div>

                                                <div class="content">

                                                    <!-- DYNAMIC FEEDBACK -->
                                                    <p>
                                                        <%# Eval("feedback") %>
                                                    </p>

                                                </div>

                                            </div>

                                        </div>

                                    </ItemTemplate>

                                </asp:Repeater>

                            </div>

                        </div>

                    </div>

                    <div class="testimonial-img-wrapper image-hover-effect">

                        <img src="assets/images/home-v1/testimonial/testimonail-bg.png"
                            alt="testimonial-bg">

                    </div>

                </div>
            </div>

        </div>
    </div>
</section>
</asp:Content>

