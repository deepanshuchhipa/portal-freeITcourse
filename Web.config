<?xml version="1.0"?>

<configuration>

  <!-- 🔗 CONNECTION STRING -->
  <connectionStrings>
    <add name="course"
         connectionString="Data Source=localhost;Initial Catalog=freecourse;Integrated Security=True;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.web>
    <compilation debug="false" targetFramework="4.5">
      <assemblies>
        <add assembly="System.Net.Http, Version=4.1.1.3, Culture=neutral, PublicKeyToken=B03F5F7F11D50A3A"/>
      </assemblies>
    </compilation>
    <httpRuntime targetFramework="4.5"/>
  </system.web>

</configuration>